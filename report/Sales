<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>상담부 매출현황 분석</title>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body { background: #0d0d14; color: #e8e8f0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; padding: 24px; }

h1 { font-size: 22px; font-weight: 700; color: #fff; margin-bottom: 4px; }
.subtitle { font-size: 12px; color: #666; margin-bottom: 24px; }

.tabs { display: flex; gap: 8px; margin-bottom: 20px; flex-wrap: wrap; }
.tab { padding: 6px 16px; font-size: 12px; border-radius: 20px; border: 1px solid #333; background: #1a1a2e; color: #888; cursor: pointer; transition: all 0.2s; }
.tab.active { background: #4f8ef7; border-color: #4f8ef7; color: #fff; }

.grid { display: grid; gap: 16px; }
.grid-2 { grid-template-columns: 1fr 1fr; }
.grid-3 { grid-template-columns: repeat(3, 1fr); }
.grid-4 { grid-template-columns: repeat(4, 1fr); }

@media (max-width: 900px) { .grid-2, .grid-3, .grid-4 { grid-template-columns: 1fr 1fr; } }
@media (max-width: 600px) { .grid-2, .grid-3, .grid-4 { grid-template-columns: 1fr; } }

.card { background: #1a1a2e; border: 1px solid #2a2a40; border-radius: 12px; padding: 16px; }
.card-title { font-size: 11px; color: #666; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 1px; }
.card-val { font-size: 26px; font-weight: 700; color: #fff; }
.card-val.blue { color: #4f8ef7; }
.card-val.green { color: #34c77b; }
.card-val.amber { color: #f5a623; }
.card-val.red { color: #f75f4f; }
.card-sub { font-size: 11px; color: #555; margin-top: 4px; }

.section { margin-bottom: 28px; }
.section-title { font-size: 13px; font-weight: 700; color: #aaa; margin-bottom: 12px; padding-bottom: 8px; border-bottom: 1px solid #2a2a40; display: flex; align-items: center; gap: 8px; }
.badge { font-size: 10px; padding: 2px 8px; border-radius: 10px; background: #2a2a40; color: #666; }
.badge.event { background: #2a1a3e; color: #a066ff; }
.badge.up { background: #1a2e1a; color: #34c77b; }
.badge.down { background: #2e1a1a; color: #f75f4f; }

/* 차트 */
.chart-wrap { position: relative; width: 100%; height: 220px; }
canvas { width: 100% !important; }

/* 바 차트 커스텀 */
.bar-chart { display: flex; align-items: flex-end; gap: 4px; height: 160px; padding: 0 4px; }
.bar-group { display: flex; flex-direction: column; align-items: center; flex: 1; gap: 4px; }
.bar { width: 100%; border-radius: 4px 4px 0 0; transition: opacity 0.2s; cursor: pointer; min-height: 2px; }
.bar:hover { opacity: 0.75; }
.bar-label { font-size: 9px; color: #555; white-space: nowrap; text-align: center; margin-top: 4px; }
.bar-val { font-size: 9px; color: #888; white-space: nowrap; }

/* 테이블 */
.tbl { width: 100%; border-collapse: collapse; font-size: 11px; }
.tbl th { background: #12122a; color: #666; padding: 8px 10px; text-align: left; font-weight: 600; border-bottom: 1px solid #2a2a40; white-space: nowrap; }
.tbl th.r { text-align: right; }
.tbl td { padding: 8px 10px; border-bottom: 1px solid #1e1e32; color: #ccc; }
.tbl td.r { text-align: right; font-variant-numeric: tabular-nums; }
.tbl tr:hover td { background: #1e1e32; }
.tbl tr.highlight td { background: #1a2a3a; }
.tbl .name { font-weight: 600; color: #e8e8f0; }
.tbl .num-blue { color: #4f8ef7; font-weight: 600; }
.tbl .num-green { color: #34c77b; font-weight: 600; }
.tbl .num-amber { color: #f5a623; font-weight: 600; }
.rank { display: inline-flex; width: 22px; height: 22px; border-radius: 50%; align-items: center; justify-content: center; font-size: 10px; font-weight: 700; background: #2a2a40; color: #888; }
.rank.gold { background: #3a2a00; color: #f5a623; }
.rank.silver { background: #2a2a3a; color: #aaa; }
.rank.bronze { background: #2a1a00; color: #c87b3f; }

/* 이벤트 타임라인 */
.timeline { display: flex; flex-direction: column; gap: 10px; }
.tl-item { display: flex; gap: 12px; align-items: flex-start; }
.tl-dot { width: 8px; height: 8px; border-radius: 50%; margin-top: 5px; flex-shrink: 0; }
.tl-dot.red { background: #f75f4f; }
.tl-dot.green { background: #34c77b; }
.tl-dot.blue { background: #4f8ef7; }
.tl-dot.amber { background: #f5a623; }
.tl-dot.purple { background: #a066ff; }
.tl-text { font-size: 11px; color: #aaa; line-height: 1.5; }
.tl-month { font-size: 10px; color: #555; display: block; }

/* 인원 차트 */
.staff-bar { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
.staff-label { font-size: 10px; color: #888; width: 36px; text-align: right; flex-shrink: 0; }
.staff-track { flex: 1; background: #12122a; border-radius: 4px; height: 14px; overflow: hidden; }
.staff-fill { height: 100%; border-radius: 4px; transition: width 0.3s; background: #4f8ef7; display: flex; align-items: center; justify-content: flex-end; padding-right: 4px; }
.staff-fill span { font-size: 9px; color: #fff; font-weight: 700; }
</style>
</head>
<body>

