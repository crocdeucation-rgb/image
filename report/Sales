<script>
// ── 원본 데이터 ──
const months = ['25.06','25.07','25.08','25.09','25.10','25.11','25.12','26.01','26.02','26.03','26.04','26.05','26.06*'];

const data = [
  // total, intu, jisa, visit, seting, order, staff_intu, note
  { m:'25.06', total:932590000,  intu:763721000, jisa:149385000, visit:855, set:478, order:262, staff_intu:78, staff_jisa:25, note:'악어에듀 80%퇴사' },
  { m:'25.07', total:1050410573, intu:801566573, jisa:226298000, visit:930, set:576, order:287, staff_intu:67, staff_jisa:27, note:'' },
  { m:'25.08', total:972169600,  intu:711881000, jisa:219907600, visit:786, set:489, order:257, staff_intu:72, staff_jisa:20, note:'' },
  { m:'25.09', total:654793000,  intu:559673000, jisa:73032000,  visit:834, set:453, order:195, staff_intu:77, staff_jisa:20, note:'악어에듀 폐업(10/31)' },
  { m:'25.10', total:748413000,  intu:620117000, jisa:104235000, visit:889, set:479, order:234, staff_intu:80, staff_jisa:21, note:'' },
  { m:'25.11', total:815496000,  intu:624114000, jisa:170765000, visit:824, set:458, order:226, staff_intu:76, staff_jisa:21, note:'가산연합센터·파인더분리' },
  { m:'25.12', total:934807000,  intu:725490000, jisa:192240000, visit:946, set:496, order:261, staff_intu:90, staff_jisa:23, note:'' },
  { m:'26.01', total:968864500,  intu:763091500, jisa:176535000, visit:1042,set:569, order:281, staff_intu:85, staff_jisa:24, note:'딱공+웹마케팅합류' },
  { m:'26.02', total:836770600,  intu:693141000, jisa:113496000, visit:835, set:445, order:225, staff_intu:83, staff_jisa:26, note:'ODI플랜메타광고시작' },
  { m:'26.03', total:957551300,  intu:739366000, jisa:185161000, visit:979, set:502, order:249, staff_intu:75, staff_jisa:24, note:'마포연합센터출범' },
  { m:'26.04', total:747657800,  intu:578357000, jisa:126029000, visit:948, set:454, order:226, staff_intu:66, staff_jisa:23, note:'' },
  { m:'26.05', total:876110100,  intu:686814500, jisa:174347000, visit:887, set:538, order:261, staff_intu:67, staff_jisa:24, note:'' },
  { m:'26.06*',total:537522200,  intu:334425000, jisa:83115000,  visit:532, set:284, order:148, staff_intu:60, staff_jisa:21, note:'진행중 / 웹마케팅1위' },
];

// 지점별 데이터 (주요 지점)
const branches = {
  '부천지점':    [186817,171777,0,179759,138488,161923,165076,184201,178958,183893,179759,0,0],
  '악어에듀':    [160530,0,116479,0,22287,38148,0,0,0,0,0,0,0],
  '수호에듀':    [105328,72734,116479,130275,37362,54815,109525,72734,116479,130275,37362,0,59995],
  '부평지점':    [88488,88518,104101,123542,92671,112296,109881,88518,104101,103273,92671,145722,47605],
  '마곡지점':    [138324,115937,98278,120247,91213,70232,128496,115937,98278,86551,120247,76833,40171],
  '가산연합센터':[0,0,0,0,0,0,0,51003,58511,108215,139310,136558,102072],
  '웹마케팅':    [0,0,0,0,0,0,0,0,16072,7803,14782,78655,102773],
};

const branchMonths = ['25.06','25.07','25.08','25.09','25.10','25.11','25.12','26.01','26.02','26.03','26.04','26.05','26.06*'];

function fmt(n) {
  if (n >= 100000000) return (n/100000000).toFixed(1)+'억';
  if (n >= 10000000)  return Math.round(n/10000000)+'천만';
  if (n >= 1000000)   return Math.round(n/1000000)+'M';
  return n.toLocaleString();
}
function fmtM(n) { return Math.round(n/1000000)+'M'; }
function pct(a,b) { return b ? Math.round(a/b*100)+'%' : '-'; }

// ── 탭 전환 ──
function showTab(id) {
  document.querySelectorAll('.tab-content').forEach(el => el.style.display='none');
  document.getElementById('tab-'+id).style.display='block';
  document.querySelectorAll('.tabs .tab').forEach((b,i) => {
    b.classList.toggle('active', b.getAttribute('onclick').includes("'"+id+"'"));
  });
  if (id==='overview') renderOverview();
  if (id==='trend')    renderTrend();
  if (id==='branch')   renderBranch('all');
  if (id==='staff')    renderStaff();
}

// ── 바 그리기 ──
function drawBars(containerId, vals, labels, colors, maxVal) {
  const el = document.getElementById(containerId);
  if (!el) return;
  const mx = maxVal || Math.max(...vals);
  el.innerHTML = vals.map((v,i) => `
    <div class="bar-group">
      <div class="bar-val">${fmtM(v)}</div>
      <div class="bar" style="height:${Math.max(2, Math.round(v/mx*120))}px;background:${colors[i]||colors[0]};" title="${labels[i]}: ${fmtM(v)}"></div>
      <div class="bar-label">${labels[i]}</div>
    </div>
  `).join('');
}

function renderOverview() {
  const cols = data.map((_,i) => {
    const isLow = data[i].total < 800000000;
    return isLow ? '#f75f4f' : '#4f8ef7';
  });
  drawBars('overview-bar', data.map(d=>d.total), months, cols);

  // 전환율
  const cvt = data.map(d => Math.round(d.order/d.visit*100));
  const convEl = document.getElementById('conv-bar');
  if (convEl) {
    const mx = Math.max(...cvt);
    convEl.innerHTML = cvt.map((v,i) => `
      <div class="bar-group">
        <div class="bar-val">${v}%</div>
        <div class="bar" style="height:${Math.max(2,Math.round(v/mx*100))}px;background:${v>=30?'#34c77b':v>=25?'#f5a623':'#f75f4f'};" title="${months[i]}: ${v}%"></div>
        <div class="bar-label">${months[i]}</div>
      </div>
    `).join('');
  }

  // 인투 vs 지사 split
  const wrap = document.getElementById('split-chart');
  wrap.innerHTML = data.map(d => {
    const total = d.intu + d.jisa;
    const ipct = Math.round(d.intu/total*100);
    return `<div style="display:flex;align-items:center;gap:6px;margin-bottom:5px;">
      <span style="font-size:9px;color:#555;width:36px;">${d.m}</span>
      <div style="flex:1;height:10px;background:#12122a;border-radius:3px;overflow:hidden;">
        <div style="width:${ipct}%;height:100%;background:#4f8ef7;border-radius:3px;"></div>
      </div>
      <span style="font-size:9px;color:#888;">${ipct}%인투</span>
    </div>`;
  }).join('');
}

function renderTrend() {
  const tbody = document.getElementById('monthly-tbody');
  tbody.innerHTML = data.map((d,i) => {
    const cvt = pct(d.order, d.visit);
    const prev = i>0 ? data[i-1].total : null;
    const diff = prev ? d.total - prev : 0;
    const diffStr = prev ? (diff>=0?'▲':'▼')+(Math.abs(diff/1000000)).toFixed(0)+'M' : '-';
    const diffColor = diff>=0?'#34c77b':'#f75f4f';
    return `<tr${d.note?` class="highlight"`:''}">
      <td class="name">${d.m}</td>
      <td class="r num-blue">${fmt(d.total)}</td>
      <td class="r">${fmt(d.intu)}</td>
      <td class="r">${fmt(d.jisa)}</td>
      <td class="r">${d.visit.toLocaleString()}</td>
      <td class="r">${d.set.toLocaleString()}</td>
      <td class="r num-green">${d.order}</td>
      <td class="r num-amber">${cvt}</td>
      <td class="r">${d.staff_intu}</td>
      <td class="r">${d.staff_jisa}</td>
      <td class="r">${d.staff_intu+d.staff_jisa}</td>
      <td style="color:#888;font-size:10px;">${d.note||''} <span style="color:${diffColor};font-size:10px;">${diffStr}</span></td>
    </tr>`;
  }).join('');
}

function renderBranch(period) {
  // 기간 필터
  let idxRange;
  if (period==='25h2') idxRange=[0,6];
  else if (period==='26h1') idxRange=[7,12];
  else idxRange=[0,12];

  const totals = {};
  Object.entries(branches).forEach(([name, vals]) => {
    totals[name] = vals.slice(idxRange[0], idxRange[1]+1).reduce((a,b)=>a+b,0);
  });

  const sorted = Object.entries(totals).sort((a,b)=>b[1]-a[1]);
  const maxVal = sorted[0][1];

  // 테이블
  const tbl = document.getElementById('branch-table');
  tbl.innerHTML = `<thead><tr>
    <th>순위</th><th>지점</th><th class="r">누적 매출</th><th class="r">비중</th><th>상태</th>
  </tr></thead><tbody>${sorted.map(([name,val],i) => {
    const rankClass = i===0?'gold':i===1?'silver':i===2?'bronze':'';
    const total13 = sorted.reduce((a,b)=>a+b[1],0);
    const isSpecial = name==='웹마케팅'?'🚀 신규':name==='악어에듀'?'❌ 폐업':name==='가산연합센터'?'🆕 신설':'';
    return `<tr>
      <td><span class="rank ${rankClass}">${i+1}</span></td>
      <td class="name">${name}</td>
      <td class="r num-blue">${fmt(val*1000)}</td>
      <td class="r">${Math.round(val/total13*100)}%</td>
      <td style="font-size:10px;color:#888;">${isSpecial}</td>
    </tr>`;
  }).join('')}</tbody>`;

  // 바 차트
  const wrap = document.getElementById('branch-bar-wrap');
  const maxBar = sorted[0][1];
  wrap.innerHTML = `<div style="display:flex;flex-direction:column;gap:8px;">` + sorted.map(([name,val]) => `
    <div style="display:flex;align-items:center;gap:8px;">
      <span style="font-size:10px;color:#888;width:90px;text-align:right;flex-shrink:0;">${name}</span>
      <div style="flex:1;background:#12122a;border-radius:4px;height:18px;overflow:hidden;">
        <div style="width:${Math.round(val/maxBar*100)}%;height:100%;background:${name==='웹마케팅'?'#f5a623':name==='악어에듀'?'#f75f4f':'#4f8ef7'};border-radius:4px;transition:width 0.4s;"></div>
      </div>
      <span style="font-size:10px;color:#888;width:60px;">${fmt(val*1000)}</span>
    </div>
  `).join('') + '</div>';
}

function filterBranch(p) {
  document.querySelectorAll('#tab-branch .tab').forEach(b => {
    b.classList.toggle('active', b.getAttribute('onclick').includes("'"+p+"'"));
  });
  renderBranch(p);
}

function renderStaff() {
  const maxStaff = Math.max(...data.map(d=>d.staff_intu + d.staff_jisa));
  const staffEl = document.getElementById('staff-bars');
  staffEl.innerHTML = data.map(d => {
    const total = d.staff_intu + d.staff_jisa;
    const intuPct = Math.round(d.staff_intu/maxStaff*100);
    const jisaPct = Math.round(d.staff_jisa/maxStaff*100);
    return `
    <div class="staff-bar" style="align-items:center;">
      <span class="staff-label">${d.m}</span>
      <div style="flex:1;display:flex;flex-direction:column;gap:2px;">
        <div style="display:flex;align-items:center;gap:4px;">
          <div style="width:${intuPct}%;background:#4f8ef7;height:10px;border-radius:3px;min-width:2px;"></div>
          <span style="font-size:9px;color:#4f8ef7;">인투 ${d.staff_intu}</span>
        </div>
        <div style="display:flex;align-items:center;gap:4px;">
          <div style="width:${jisaPct}%;background:#f5a623;height:10px;border-radius:3px;min-width:2px;"></div>
          <span style="font-size:9px;color:#f5a623;">지사 ${d.staff_jisa}</span>
        </div>
      </div>
      <span style="font-size:11px;font-weight:700;color:#fff;width:36px;text-align:right;">총 ${total}</span>
      <span style="font-size:9px;color:#555;margin-left:8px;width:80px;">${d.note||''}</span>
    </div>`;
  }).join('');

  // 1인당 효율
  const etbl = document.getElementById('efficiency-table');
  etbl.innerHTML = `<thead><tr>
    <th>월</th><th class="r">인투</th><th class="r">지사</th><th class="r">합계</th><th class="r">총매출</th><th class="r">1인당 월매출</th><th class="r">방문/인</th><th class="r">오더/인</th>
  </tr></thead><tbody>` + data.map(d => {
    const total = d.staff_intu + d.staff_jisa;
    const perPerson = Math.round(d.total/total/10000);
    return `<tr>
      <td class="name">${d.m}</td>
      <td class="r" style="color:#4f8ef7;">${d.staff_intu}</td>
      <td class="r" style="color:#f5a623;">${d.staff_jisa}</td>
      <td class="r num-blue">${total}</td>
      <td class="r">${fmt(d.total)}</td>
      <td class="r num-amber">${perPerson}만원</td>
      <td class="r">${(d.visit/total).toFixed(1)}</td>
      <td class="r num-green">${(d.order/total).toFixed(1)}</td>
    </tr>`;
  }).join('') + '</tbody>';
}

